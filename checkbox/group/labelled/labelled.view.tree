$eve_checkbox_group_labelled $eve_checkbox_labelled
	sub /
		<= Checkbox $eve_checkbox
			click_toggle? false
			checked? <=> checked? false
			disabled? <=> disabled? false
			indeterminate? <=> indeterminate? false
			event_click?event <=> option_click?event null
		<= Label $mol_text
			text <= label \
